                "subtitleKey": "email"
              }
            },
            {
              "type": "remote.chat-box",
              "id": "workbench-crm-chat",
              "props": {
                "streamEndpoint": "/workbench/remote/chat/stream",
                "historyEndpoint": "/workbench/remote/chat/history",
                "audience": "https://crm.workbench.test",
                "scopes": ["chat.read", "chat.write"],
                "title": "Remote CRM assistant",
                "placeholder": "Ask the remote CRM"
              }
            }
          ]
        }
      ]
    }
  ]
