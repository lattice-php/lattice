{
  "version": 1,
  "schema": [
    {
      "type": "section",
      "id": "workbench-crm-overview",
      "props": {
        "title": "Workbench CRM",
        "description": "This section is resolved from a remote schema source."
      },
      "schema": [
        {
          "type": "card",
          "id": "workbench-crm-card",
          "props": {
            "title": "Remote customer context",
