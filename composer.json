{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "lattice-php/lattice",
    "description": "Server-driven React components for Laravel and Inertia.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "inertia",
        "react",
        "server-driven-ui"
    ],
    "homepage": "https://latticephp.com",
    "support": {
        "issues": "https://github.com/lattice-php/lattice/issues",
        "source": "https://github.com/lattice-php/lattice",
        "docs": "https://latticephp.com"
    },
    "authors": [
        {
            "name": "Manuel Christlieb",
            "email": "manuel@christlieb.eu"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "inertiajs/inertia-laravel": "^3.0",
        "spatie/laravel-package-tools": "^1.16 || ^2.0",
        "spatie/php-attribute-reader": "^1.1",
        "spatie/php-structure-discoverer": "^2.4",
        "symfony/html-sanitizer": "^8.1",
        "ueberdosis/tiptap-php": "^2.1"
    },
    "require-dev": {
        "bambamboole/laravel-i18next": "^0.6.0",
        "barryvdh/laravel-ide-helper": "^3.7",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.16",
        "mrpunyapal/peststan": "^0.2.10",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.0",
        "rector/rector": "^2.4",
        "spatie/laravel-typescript-transformer": "^3.2"
    },
    "suggest": {
        "spatie/typescript-transformer": "Required to run `php artisan lattice:typescript` and generate TypeScript types for your custom components"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Lattice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Lattice\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "analyse": "./vendor/bin/phpstan analyse",
        "check": [
            "@test:lint",
            "@analyse",
            "@test"
        ],
        "lint": "./vendor/bin/pint",
        "test:lint": "./vendor/bin/pint --test",
        "rector": "./vendor/bin/rector process",
        "rector:test": "./vendor/bin/rector process --dry-run",
        "types": "@php vendor/bin/testbench lattice:typescript",
        "fix": [
            "@rector",
            "@lint",
            "npm run lint:fix",
            "npm run format",
            "@types"
        ],
        "test": "./vendor/bin/pest --testsuite Arch,Unit,Feature",
        "test:browser": "./vendor/bin/pest --testsuite Browser",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lattice\\Lattice\\LatticeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
