---
import { Code, TabItem, Tabs } from "@astrojs/starlight/components";
import Preview from "@components/Preview.tsx";
import NodeTree from "@components/NodeTree.tsx";
import TokenList from "@components/TokenList.tsx";
import { suffixMap, tokenRegistry } from "@lib/themeTokens.ts";

interface Props {
  php: string;
  fixture: string;
  values?: Record<string, unknown>;
}

const { php, fixture, values = {} } = Astro.props;

const fixtures = import.meta.glob<{ default: unknown[] }>("../fixtures/*.json", {
  eager: true,
});

const entry = fixtures[`../fixtures/${fixture}.json`];

if (!entry) {
  throw new Error(`Unknown fixture "${fixture}". Did a test dump it to docs/fixtures/?`);
}

const nodes = entry.default;
---

<Tabs>
  <TabItem label="PHP">
    <Code code={php} lang="php" />
  </TabItem>
  <TabItem label="Preview">
    <div class="example-preview not-content">
      <Preview client:only="react" nodes={nodes} values={values} />
    </div>
  </TabItem>
  <TabItem label="Tree">
    <div class="example-preview not-content">
      <NodeTree client:load nodes={nodes} />
    </div>
  </TabItem>
  <TabItem label="Style">
    <div class="example-preview not-content">
      <TokenList
        client:only="react"
        nodes={nodes}
        values={values}
        tokens={tokenRegistry}
        suffixMap={suffixMap}
      />
    </div>
  </TabItem>
</Tabs>

<style>
  .example-preview {
    padding: 1.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg);
  }
</style>
