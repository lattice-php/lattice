---
/**
 * Renders the current bundle composition from the Sonda JSON report, which is
 * regenerated on every docs build by `npm run analyze` (see package.json).
 * The numbers below are therefore always in sync with the latest build.
 */
type Resource = {
  kind: "filesystem" | "sourcemap" | "chunk" | "asset";
  name: string;
  type: string;
  uncompressed: number;
  gzip?: number;
};

type Report = {
  metadata: { version: string; generatedAt: string; gzip: boolean };
  resources: Resource[];
};

const reports = import.meta.glob<{ default: Report }>("../generated/bundle-report.json", {
  eager: true,
});

const report = reports["../generated/bundle-report.json"]?.default ?? null;

const kb = (bytes: number): string => `${(bytes / 1024).toFixed(1)} KB`;

function group(name: string): string {
  if (name.includes("resources/js")) return "Lattice (own code)";
  const at = name.lastIndexOf("node_modules/");
  if (at < 0) return "Application / other";
  const rest = name.slice(at + "node_modules/".length);
  const pkg = rest.startsWith("@") ? rest.split("/").slice(0, 2).join("/") : rest.split("/")[0];
  if (pkg.startsWith("@tiptap") || pkg.startsWith("prosemirror") || pkg === "linkifyjs") {
    return "TipTap + ProseMirror (rich editor)";
  }
  if (pkg.startsWith("@radix-ui") || pkg.startsWith("@floating-ui")) return "Radix UI";
  if (pkg === "react" || pkg === "react-dom" || pkg === "scheduler") return "React / React-DOM";
  if (pkg === "i18next" || pkg.startsWith("i18next-") || pkg === "react-i18next") return "i18next";
  if (pkg.startsWith("@inertiajs")) return "Inertia";
  return pkg;
}

let files: Resource[] = [];
let contributors: Array<{ name: string; uncompressed: number; gzip: number }> = [];
let totalRaw = 0;
let totalGz = 0;

if (report) {
  files = report.resources
    .filter((r) => r.kind === "asset" && r.type === "script")
    .sort((a, b) => b.uncompressed - a.uncompressed);

  const agg = new Map<string, { uncompressed: number; gzip: number }>();
  for (const r of report.resources.filter((r) => r.kind === "chunk")) {
    const g = group(r.name);
    const cur = agg.get(g) ?? { uncompressed: 0, gzip: 0 };
    cur.uncompressed += r.uncompressed;
    cur.gzip += r.gzip ?? 0;
    agg.set(g, cur);
    totalRaw += r.uncompressed;
    totalGz += r.gzip ?? 0;
  }
  contributors = [...agg.entries()]
    .map(([name, v]) => ({ name, ...v }))
    .sort((a, b) => b.uncompressed - a.uncompressed)
    .slice(0, 12);
}

const generatedAt = report ? new Date(report.metadata.generatedAt).toUTCString() : null;
const fileLabel = (name: string): string => name.replace(/.*\/assets\//, "").replace(/.*\//, "");
---

{
  !report ? (
    <aside class="bundle-report-missing">
      <strong>Bundle report not generated.</strong> Run <code>npm run analyze</code> (or
      <code>npm run docs:build</code>, which runs it for you) to produce
      <code>docs/public/bundle-report.json</code>.
    </aside>
  ) : (
    <div class="bundle-report">
      <p class="bundle-report-total">
        <strong>{kb(totalRaw)}</strong> of JavaScript total — <strong>{kb(totalGz)} gzipped</strong>.
      </p>

      <h3>Emitted JavaScript files</h3>
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th style="text-align:right">Raw</th>
            <th style="text-align:right">Gzip</th>
          </tr>
        </thead>
        <tbody>
          {files.map((f) => (
            <tr>
              <td>
                <code>{fileLabel(f.name)}</code>
              </td>
              <td style="text-align:right">{kb(f.uncompressed)}</td>
              <td style="text-align:right">{kb(f.gzip ?? 0)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3>What it consists of</h3>
      <p>Every module in the bundle, attributed to the dependency it came from:</p>
      <table>
        <thead>
          <tr>
            <th>Dependency</th>
            <th style="text-align:right">Raw</th>
            <th style="text-align:right">Gzip</th>
          </tr>
        </thead>
        <tbody>
          {contributors.map((c) => (
            <tr>
              <td>{c.name}</td>
              <td style="text-align:right">{kb(c.uncompressed)}</td>
              <td style="text-align:right">{kb(c.gzip)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <h3>Interactive treemap</h3>
      <iframe
        class="bundle-report-frame"
        src="/bundle-report.html"
        title="Sonda bundle report"
        loading="lazy"
      />
      <p class="bundle-report-meta">
        <a href="/bundle-report.html" target="_blank" rel="noopener">
          Open the full report in a new tab ↗
        </a>{" "}
        · Generated by Sonda {report.metadata.version} on {generatedAt}.
      </p>
    </div>
  )
}

<style>
  .bundle-report-total {
    font-size: var(--sl-text-h4);
  }
  .bundle-report-frame {
    width: 100%;
    height: 720px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-black);
  }
  .bundle-report-meta {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }
  .bundle-report-missing {
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.5rem;
    padding: 1rem;
  }
  .bundle-report-missing code {
    white-space: nowrap;
  }
</style>
